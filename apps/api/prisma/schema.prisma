generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  COORDINATOR
  TEACHER
  STUDENT
  GUARDIAN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum InterventionStatus {
  OPEN
  IN_PROGRESS
  WAITING_GUARDIAN
  RESOLVED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum AnnouncementAudience {
  ALL
  CLASS
  STUDENT
  GUARDIAN
  TEACHER
}

// ─── School & Tenancy ────────────────────────────────────────────────────────

model School {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users             User[]
  students          Student[]
  teachers          Teacher[]
  classes           Class[]
  subjects          Subject[]
  academicYears     AcademicYear[]
  announcements     Announcement[]
  interventionPlans InterventionPlan[]
  auditLogs         AuditLog[]
  notifications     Notification[]

  @@map("schools")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  schoolId     String
  email        String
  passwordHash String
  name         String
  role         UserRole
  avatarUrl    String?
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school            School                  @relation(fields: [schoolId], references: [id])
  teacher           Teacher?
  guardian          Guardian?
  student           Student?
  interventionOwned InterventionPlan[]       @relation("InterventionOwner")
  auditLogs         AuditLog[]
  notifications     Notification[]
  authoredAnnouncements Announcement[]      @relation("AnnouncementAuthor")
  announcementRecipients AnnouncementRecipient[] @relation("AnnouncementRecipientUser")

  @@unique([schoolId, email])
  @@map("users")
}

// ─── Students ────────────────────────────────────────────────────────────────

model Student {
  id              String    @id @default(cuid())
  schoolId        String
  userId          String?   @unique
  registrationId  String
  name            String
  birthDate       DateTime?
  gender          String?
  photoUrl        String?
  address         String?
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  school            School              @relation(fields: [schoolId], references: [id])
  user              User?               @relation(fields: [userId], references: [id])
  guardians         StudentGuardian[]
  enrollments       Enrollment[]
  attendanceRecords AttendanceRecord[]
  grades            Grade[]
  occurrences       Occurrence[]
  riskScores        RiskScore[]
  interventionPlans InterventionPlan[]
  timelineEvents    StudentTimeline[]
  announcementRecipients AnnouncementRecipient[]

  @@unique([schoolId, registrationId])
  @@map("students")
}

model Guardian {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String   @unique
  name      String
  cpf       String?
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  students StudentGuardian[]

  @@map("guardians")
}

model StudentGuardian {
  id           String  @id @default(cuid())
  studentId    String
  guardianId   String
  relationship String
  isPrimary    Boolean @default(false)

  student  Student  @relation(fields: [studentId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@unique([studentId, guardianId])
  @@map("student_guardians")
}

// ─── Teachers ────────────────────────────────────────────────────────────────

model Teacher {
  id           String   @id @default(cuid())
  schoolId     String
  userId       String   @unique
  registrationId String?
  specialties  String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school      School             @relation(fields: [schoolId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
  assignments TeacherAssignment[]

  @@map("teachers")
}

// ─── Academic Structure ──────────────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School          @relation(fields: [schoolId], references: [id])
  terms   AcademicTerm[]
  classes Class[]

  @@map("academic_years")
}

model AcademicTerm {
  id             String   @id @default(cuid())
  academicYearId String
  name           String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  assessments  Assessment[]

  @@map("academic_terms")
}

model Class {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  grade          String
  shift          String?
  maxStudents    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school          School              @relation(fields: [schoolId], references: [id])
  academicYear    AcademicYear        @relation(fields: [academicYearId], references: [id])
  enrollments     Enrollment[]
  classSubjects   ClassSubject[]

  @@map("classes")
}

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school        School             @relation(fields: [schoolId], references: [id])
  classSubjects ClassSubject[]
  assessments   Assessment[]

  @@map("subjects")
}

model ClassSubject {
  id        String @id @default(cuid())
  classId   String
  subjectId String

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  assignments       TeacherAssignment[]
  attendanceSessions AttendanceSession[]

  @@unique([classId, subjectId])
  @@map("class_subjects")
}

model TeacherAssignment {
  id             String @id @default(cuid())
  teacherId      String
  classSubjectId String

  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  classSubject ClassSubject @relation(fields: [classSubjectId], references: [id])

  @@unique([teacherId, classSubjectId])
  @@map("teacher_assignments")
}

model Enrollment {
  id             String   @id @default(cuid())
  studentId      String
  classId        String
  enrolledAt     DateTime @default(now())
  unenrolledAt   DateTime?
  isActive       Boolean  @default(true)

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId])
  @@map("enrollments")
}

// ─── Attendance ──────────────────────────────────────────────────────────────

model AttendanceSession {
  id             String   @id @default(cuid())
  classSubjectId String
  date           DateTime
  createdByUserId String?
  createdAt      DateTime @default(now())

  classSubject ClassSubject       @relation(fields: [classSubjectId], references: [id])
  records      AttendanceRecord[]

  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  sessionId String
  studentId String
  status    AttendanceStatus
  note      String?

  session AttendanceSession @relation(fields: [sessionId], references: [id])
  student Student           @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}

// ─── Assessments & Grades ────────────────────────────────────────────────────

model Assessment {
  id             String   @id @default(cuid())
  schoolId       String?
  subjectId      String
  academicTermId String
  title          String
  description    String?
  weight         Decimal  @default(1)
  maxScore       Decimal  @default(10)
  date           DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subject      Subject      @relation(fields: [subjectId], references: [id])
  academicTerm AcademicTerm @relation(fields: [academicTermId], references: [id])
  grades       Grade[]

  @@map("assessments")
}

model Grade {
  id           String   @id @default(cuid())
  studentId    String
  assessmentId String
  score        Decimal
  feedback     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student    Student    @relation(fields: [studentId], references: [id])
  assessment Assessment @relation(fields: [assessmentId], references: [id])

  @@unique([studentId, assessmentId])
  @@map("grades")
}

// ─── Occurrences ─────────────────────────────────────────────────────────────

model Occurrence {
  id          String   @id @default(cuid())
  schoolId    String?
  studentId   String
  reportedBy  String?
  type        String
  description String
  date        DateTime
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@map("occurrences")
}

// ─── Communication ───────────────────────────────────────────────────────────

model Announcement {
  id        String               @id @default(cuid())
  schoolId  String
  authorId  String?
  title     String
  content   String
  audience  AnnouncementAudience @default(ALL)
  classId   String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  school     School                  @relation(fields: [schoolId], references: [id])
  author     User?                   @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  recipients AnnouncementRecipient[]

  @@map("announcements")
}

model AnnouncementRecipient {
  id             String    @id @default(cuid())
  announcementId String
  studentId      String?
  userId         String?
  readAt         DateTime?

  announcement Announcement @relation(fields: [announcementId], references: [id])
  student      Student?     @relation(fields: [studentId], references: [id])
  user         User?        @relation("AnnouncementRecipientUser", fields: [userId], references: [id])

  @@map("announcement_recipients")
}

// ─── Student Success Engine ───────────────────────────────────────────────────

model RiskScore {
  id          String    @id @default(cuid())
  studentId   String
  score       Int
  level       RiskLevel
  factors     Json
  calculatedAt DateTime @default(now())

  student           Student           @relation(fields: [studentId], references: [id])
  interventionPlans InterventionPlan[]

  @@map("risk_scores")
}

model InterventionPlan {
  id           String             @id @default(cuid())
  schoolId     String
  studentId    String
  riskScoreId  String?
  ownerUserId  String
  status       InterventionStatus @default(OPEN)
  reason       String
  goal         String
  startDate    DateTime           @default(now())
  reviewDate   DateTime
  closedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  school    School    @relation(fields: [schoolId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
  riskScore RiskScore? @relation(fields: [riskScoreId], references: [id])
  owner     User      @relation("InterventionOwner", fields: [ownerUserId], references: [id])
  notes     InterventionNote[]

  @@map("intervention_plans")
}

model InterventionNote {
  id             String   @id @default(cuid())
  interventionId String
  authorId       String?
  content        String
  createdAt      DateTime @default(now())

  intervention InterventionPlan @relation(fields: [interventionId], references: [id])

  @@map("intervention_notes")
}

model StudentTimeline {
  id          String   @id @default(cuid())
  studentId   String
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@map("student_timeline")
}

// ─── Notifications & Audit ───────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  title     String
  body      String
  type      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  schoolId    String
  actorUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  actor  User?  @relation(fields: [actorUserId], references: [id])

  @@map("audit_logs")
}
